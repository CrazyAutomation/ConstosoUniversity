@model ContosoUniversity.Models.Department

@{
    ViewBag.Title = "Edit Department";
}

<h2 class="mt-3">Edit Department</h2>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(m => m.DepartmentID)
    @Html.HiddenFor(m => m.RowVersion)

    <div class="card shadow-sm mt-4">
        <div class="card-body">

            <h4 class="mb-3">Department Information</h4>
            <hr />

            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            <div class="mb-3">
                @Html.LabelFor(m => m.Name, new { @class = "form-label" })
                @Html.TextBoxFor(m => m.Name, new { @class = "form-control" })
                @Html.ValidationMessageFor(m => m.Name, "", new { @class = "text-danger" })
            </div>

            <div class="mb-3">
                @Html.LabelFor(m => m.Budget, new { @class = "form-label" })
                @Html.TextBoxFor(m => m.Budget, new { @class = "form-control", type = "number", step = "0.01" })
                @Html.ValidationMessageFor(m => m.Budget, "", new { @class = "text-danger" })
            </div>

            <div class="mb-3">
                @Html.LabelFor(m => m.StartDate, new { @class = "form-label" })
                @Html.TextBoxFor(m => m.StartDate, new { @class = "form-control", type = "date" })
                @Html.ValidationMessageFor(m => m.StartDate, "", new { @class = "text-danger" })
            </div>

            <div class="mb-3">
                @Html.LabelFor(m => m.InstructorID, "Administrator", new { @class = "form-label" })
                @Html.DropDownList("InstructorID", null, new { @class = "form-select" })
                @Html.ValidationMessageFor(m => m.InstructorID, "", new { @class = "text-danger" })
            </div>

            <button type="submit" class="btn btn-primary">Save</button>
            @Html.ActionLink("Back to List", "Index", null, new { @class = "btn btn-secondary ms-2" })

        </div>
    </div>
}

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
