@model ContosoUniversity.Models.Department

@{
    ViewBag.Title = "Delete Department";
}

<h2 class="mt-3 text-danger">Delete Department</h2>

@if (!String.IsNullOrEmpty(ViewBag.ConcurrencyErrorMessage))
{
    <div class="alert alert-warning mt-3">
        @ViewBag.ConcurrencyErrorMessage
    </div>
}

<h4 class="text-danger">Are you sure you want to delete this department?</h4>

<div class="card shadow-sm mt-4">
    <div class="card-body">

        <h5 class="mb-3">Department Details</h5>
        <hr />

        <dl class="row">

            <dt class="col-sm-3 fw-bold">Administrator</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.Administrator.FullName)</dd>

            <dt class="col-sm-3 fw-bold">@Html.DisplayNameFor(m => m.Name)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.Name)</dd>

            <dt class="col-sm-3 fw-bold">@Html.DisplayNameFor(m => m.Budget)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.Budget)</dd>

            <dt class="col-sm-3 fw-bold">@Html.DisplayNameFor(m => m.StartDate)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.StartDate)</dd>

        </dl>

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(m => m.DepartmentID)
            @Html.HiddenFor(m => m.RowVersion)

            <div class="mt-4">
                <button type="submit" class="btn btn-danger">Delete</button>
                @Html.ActionLink("Back to List", "Index", null, new { @class = "btn btn-secondary ms-2" })
            </div>
        }

    </div>
</div>
