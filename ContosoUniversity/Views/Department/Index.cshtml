@model IEnumerable<ContosoUniversity.Models.Department>

@{
    ViewBag.Title = "Departments";
}

<h2 class="mt-3">Departments</h2>

<div class="d-flex justify-content-between align-items-center mt-3">
    @Html.ActionLink("Create New Department", "Create", null, new { @class = "btn btn-primary" })
</div>

<div class="card shadow-sm mt-4">
    <div class="card-body">

        <table class="table table-striped table-hover mt-2">
            <thead class="table-dark">
                <tr>
                    <th>@Html.DisplayNameFor(m => m.First().Name)</th>
                    <th>@Html.DisplayNameFor(m => m.First().Budget)</th>
                    <th>@Html.DisplayNameFor(m => m.First().StartDate)</th>
                    <th>Administrator</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Name</td>
                        <td>@item.Budget.ToString("C")</td>
                        <td>@item.StartDate.ToShortDateString()</td>
                        @*<td>@item.Administrator.FullName</td>*@
                        <td>@item.Administrator?.FullName</td>

                        <td class="text-end">
                            @Html.ActionLink("Edit", "Edit", new { id = item.DepartmentID }, new { @class = "btn btn-sm btn-primary me-1" })
                            @Html.ActionLink("Details", "Details", new { id = item.DepartmentID }, new { @class = "btn btn-sm btn-info text-white me-1" })
                            @Html.ActionLink("Delete", "Delete", new { id = item.DepartmentID }, new { @class = "btn btn-sm btn-danger" })
                        </td>
                    </tr>
                }
            </tbody>
        </table>

    </div>
</div>
