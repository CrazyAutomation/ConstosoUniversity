@model ContosoUniversity.Models.Course

@{
    ViewBag.Title = "Update Course Credits";
}

<h2 class="mt-3">Update Course Credits</h2>

@if (ViewBag.RowsAffected == null)
{
    <div class="card shadow-sm mt-4">
        <div class="card-body">

            <h5 class="mb-3">Multiply All Course Credits</h5>
            <hr />

            @using (Html.BeginForm())
            {
                <div class="mb-3">
                    @Html.Label("multiplier", "Enter multiplier value", new { @class = "form-label fw-bold" })
                    @Html.TextBox("multiplier", null, new { @class = "form-control", placeholder = "e.g., 2" })
                </div>

                <button type="submit" class="btn btn-primary">Update</button>
                @Html.ActionLink("Back to List", "Index", null, new { @class = "btn btn-secondary ms-2" })
            }
        </div>
    </div>
}
else
{
    <div class="card shadow-sm mt-4">
        <div class="card-body">

            <h5 class="mb-3">Update Complete</h5>
            <hr />

            <p class="fs-5">
                <strong>@ViewBag.RowsAffected</strong> course records were updated.
            </p>

            @Html.ActionLink("Back to List", "Index", null, new { @class = "btn btn-secondary" })
        </div>
    </div>
}
