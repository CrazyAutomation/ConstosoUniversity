@model ContosoUniversity.Models.Course

@{
    ViewBag.Title = "Course Details";
}

<h2 class="mt-3">Course Details</h2>

<div class="card shadow-sm mt-4">
    <div class="card-body">

        <h4 class="mb-3">Course Information</h4>
        <hr />

        <dl class="row">

            <dt class="col-sm-3 fw-bold">Department</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.Department.Name)</dd>

            <dt class="col-sm-3 fw-bold">@Html.DisplayNameFor(m => m.CourseID)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.CourseID)</dd>

            <dt class="col-sm-3 fw-bold">@Html.DisplayNameFor(m => m.Title)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.Title)</dd>

            <dt class="col-sm-3 fw-bold">@Html.DisplayNameFor(m => m.Credits)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.Credits)</dd>

        </dl>

        <div class="mt-4">
            @Html.ActionLink("Edit", "Edit", new { id = Model.CourseID }, new { @class = "btn btn-primary" })
            @Html.ActionLink("Back to List", "Index", null, new { @class = "btn btn-secondary ms-2" })
        </div>

    </div>
</div>
