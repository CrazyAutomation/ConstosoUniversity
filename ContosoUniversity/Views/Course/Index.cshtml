@model IEnumerable<ContosoUniversity.Models.Course>

@{
    ViewBag.Title = "Courses";
}

<h2 class="mt-3">Courses</h2>

<div class="d-flex justify-content-between align-items-center mt-3">
    @Html.ActionLink("Create New Course", "Create", null, new { @class = "btn btn-primary" })
</div>

<div class="card shadow-sm mt-4">
    <div class="card-body">

        <h5 class="mb-3">Filter by Department</h5>

        @using (Html.BeginForm("Index", "Course", FormMethod.Get))
        {
            <div class="row g-3 align-items-center mb-3">
                <div class="col-auto">
                    @Html.Label("SelectedDepartment", "Department", new { @class = "form-label fw-bold" })
                </div>
                <div class="col-auto">
                    @Html.DropDownList("SelectedDepartment", null, "All", new { @class = "form-select" })
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-secondary">Filter</button>
                </div>
            </div>
        }

        <table class="table table-striped table-hover mt-3">
            <thead class="table-dark">
                <tr>
                    <th>@Html.DisplayNameFor(m => m.First().CourseID)</th>
                    <th>@Html.DisplayNameFor(m => m.First().Title)</th>
                    <th>@Html.DisplayNameFor(m => m.First().Credits)</th>
                    <th>Department</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.CourseID</td>
                        <td>@item.Title</td>
                        <td>@item.Credits</td>
                        <td>
                            @if (item.Department != null)
                            {
                                @item.Department.Name
                            }
                            else
                            {
                                <span class="text-muted">No Department</span>
                            }

                        <td class="text-end">
                            @Html.ActionLink("Edit", "Edit", new { id = item.CourseID }, new { @class = "btn btn-sm btn-primary me-1" })
                            @Html.ActionLink("Details", "Details", new { id = item.CourseID }, new { @class = "btn btn-sm btn-info text-white me-1" })
                            @Html.ActionLink("Delete", "Delete", new { id = item.CourseID }, new { @class = "btn btn-sm btn-danger" })
                        </td>
                    </tr>
                }
            </tbody>
        </table>

    </div>
</div>
