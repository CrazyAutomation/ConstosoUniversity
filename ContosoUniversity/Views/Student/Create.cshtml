@model ContosoUniversity.Models.Student

@{
    ViewBag.Title = "Create Student";
}

<h2 class="mt-3">Create Student</h2>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <div class="card shadow-sm mt-4">
        <div class="card-body">

            <h4 class="mb-3">Student Information</h4>
            <hr />

            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            <div class="mb-3">
                @Html.LabelFor(m => m.LastName, new { @class = "form-label" })
                @Html.TextBoxFor(m => m.LastName, new { @class = "form-control" })
                @Html.ValidationMessageFor(m => m.LastName, "", new { @class = "text-danger" })
            </div>

            <div class="mb-3">
                @Html.LabelFor(m => m.FirstMidName, new { @class = "form-label" })
                @Html.TextBoxFor(m => m.FirstMidName, new { @class = "form-control" })
                @Html.ValidationMessageFor(m => m.FirstMidName, "", new { @class = "text-danger" })
            </div>

            <div class="mb-3">
                @Html.LabelFor(m => m.EnrollmentDate, new { @class = "form-label" })
                @Html.TextBoxFor(m => m.EnrollmentDate, "{0:yyyy-MM-dd}",
                    new { @class = "form-control", type = "date" })
                @Html.ValidationMessageFor(m => m.EnrollmentDate, "", new { @class = "text-danger" })
            </div>

            <button type="submit" class="btn btn-primary">Create</button>
            @Html.ActionLink("Back to List", "Index", null, new { @class = "btn btn-secondary ms-2" })

        </div>
    </div>
}

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}