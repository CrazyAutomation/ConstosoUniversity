@model ContosoUniversity.Models.Student

@{
    ViewBag.Title = "Student Details";
}

<h2 class="mt-3">Student Details</h2>

<div class="card shadow-sm mt-4">
    <div class="card-body">

        <h4 class="mb-3">Student Information</h4>
        <hr />

        <dl class="row">

            <dt class="col-sm-3 fw-bold">
                @Html.DisplayNameFor(m => m.LastName)
            </dt>
            <dd class="col-sm-9">
                @Html.DisplayFor(m => m.LastName)
            </dd>

            <dt class="col-sm-3 fw-bold">
                @Html.DisplayNameFor(m => m.FirstMidName)
            </dt>
            <dd class="col-sm-9">
                @Html.DisplayFor(m => m.FirstMidName)
            </dd>

            <dt class="col-sm-3 fw-bold">
                @Html.DisplayNameFor(m => m.EnrollmentDate)
            </dt>
            <dd class="col-sm-9">
                @Html.DisplayFor(m => m.EnrollmentDate)
            </dd>

        </dl>

        <h4 class="mt-4">Enrollments</h4>
        <hr />

        @if (Model.Enrollments != null && Model.Enrollments.Any())
        {
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Course Title</th>
                        <th>Grade</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Enrollments)
                    {
                        <tr>
                            <td>@item.Course.Title</td>
                            <td>@item.Grade</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="text-muted">This student has no enrollments.</p>
        }

        <div class="mt-4">
            @Html.ActionLink("Edit", "Edit", new { id = Model.ID }, new { @class = "btn btn-primary" })
            @Html.ActionLink("Back to List", "Index", null, new { @class = "btn btn-secondary ms-2" })
        </div>

    </div>
</div>
