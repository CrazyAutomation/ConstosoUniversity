@model PagedList.IPagedList<ContosoUniversity.Models.Student>

@{
    ViewBag.Title = "Students";
}

<link href="~/Content/PagedList.css" rel="stylesheet" />

<h2 class="mt-3">Students</h2>

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        @Html.ActionLink("Create New", "Create", null, new { @class = "btn btn-primary" })
    </div>

    @using (Html.BeginForm("Index", "Student", FormMethod.Get, new { @class = "d-flex" }))
    {
        <input type="text"
               name="SearchString"
               value="@ViewBag.CurrentFilter"
               class="form-control me-2"
               placeholder="Search by name" />

        <button type="submit" class="btn btn-outline-secondary">Search</button>
    }
</div>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>
                @Html.ActionLink("Last Name", "Index",
                    new { sortOrder = ViewBag.NameSortParm, currentFilter = ViewBag.CurrentFilter })
            </th>
            <th>First Name</th>
            <th>
                @Html.ActionLink("Enrollment Date", "Index",
                    new { sortOrder = ViewBag.DateSortParm, currentFilter = ViewBag.CurrentFilter })
            </th>
            <th class="text-end">Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.LastName</td>
                <td>@item.FirstMidName</td>
                <td>@item.EnrollmentDate.ToShortDateString()</td>
                <td class="text-end">
                    @Html.ActionLink("Edit", "Edit", new { id = item.ID }, new { @class = "btn btn-sm btn-warning me-1" })
                    @Html.ActionLink("Details", "Details", new { id = item.ID }, new { @class = "btn btn-sm btn-info me-1" })
                    @Html.ActionLink("Delete", "Delete", new { id = item.ID }, new { @class = "btn btn-sm btn-danger" })
                </td>
            </tr>
        }
    </tbody>
</table>

<div class="d-flex justify-content-between align-items-center mt-3">
    <div>
        Page @Model.PageNumber of @Model.PageCount
    </div>

    
</div>