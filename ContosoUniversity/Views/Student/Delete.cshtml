@model ContosoUniversity.Models.Student

@{
    ViewBag.Title = "Delete Student";
}

<h2 class="mt-3 text-danger">Delete Student</h2>

@if (!String.IsNullOrEmpty(ViewBag.ErrorMessage))
{
    <div class="alert alert-danger">
        @ViewBag.ErrorMessage
    </div>
}

<div class="card shadow-sm mt-4">
    <div class="card-body">

        <h4 class="text-danger">Are you sure you want to delete this student?</h4>
        <hr />

        <dl class="row">

            <dt class="col-sm-3 fw-bold">
                @Html.DisplayNameFor(m => m.LastName)
            </dt>
            <dd class="col-sm-9">
                @Html.DisplayFor(m => m.LastName)
            </dd>

            <dt class="col-sm-3 fw-bold">
                @Html.DisplayNameFor(m => m.FirstMidName)
            </dt>
            <dd class="col-sm-9">
                @Html.DisplayFor(m => m.FirstMidName)
            </dd>

            <dt class="col-sm-3 fw-bold">
                @Html.DisplayNameFor(m => m.EnrollmentDate)
            </dt>
            <dd class="col-sm-9">
                @Html.DisplayFor(m => m.EnrollmentDate)
            </dd>

        </dl>

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()

            <div class="mt-4">
                <button type="submit" class="btn btn-danger">
                    <i class="bi bi-trash"></i> Delete
                </button>

                @Html.ActionLink("Back to List", "Index", null, new { @class = "btn btn-secondary ms-2" })
            </div>
        }

    </div>
</div>
