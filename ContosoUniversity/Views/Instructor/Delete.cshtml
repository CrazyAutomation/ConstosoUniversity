@model ContosoUniversity.Models.Instructor

@{
    ViewBag.Title = "Delete Instructor";
}

<h2 class="mt-3 text-danger">Delete Instructor</h2>

<h4 class="text-danger">Are you sure you want to delete this instructor?</h4>

<div class="card shadow-sm mt-4">
    <div class="card-body">

        <h5 class="mb-3">Instructor Details</h5>
        <hr />

        <dl class="row">

            <dt class="col-sm-3 fw-bold">@Html.DisplayNameFor(m => m.OfficeAssignment.Location)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.OfficeAssignment.Location)</dd>

            <dt class="col-sm-3 fw-bold">@Html.DisplayNameFor(m => m.LastName)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.LastName)</dd>

            <dt class="col-sm-3 fw-bold">@Html.DisplayNameFor(m => m.FirstMidName)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.FirstMidName)</dd>

            <dt class="col-sm-3 fw-bold">@Html.DisplayNameFor(m => m.HireDate)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.HireDate)</dd>

        </dl>

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()

            <div class="mt-4">
                <button type="submit" class="btn btn-danger">Delete</button>
                @Html.ActionLink("Back to List", "Index", null, new { @class = "btn btn-secondary ms-2" })
            </div>
        }

    </div>
</div>
