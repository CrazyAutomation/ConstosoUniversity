@model ContosoUniversity.ViewModels.InstructorIndexData

@{
    ViewBag.Title = "Instructors";
}

<h2 class="mt-3">Instructors</h2>

<div class="d-flex justify-content-between align-items-center mt-3">
    @Html.ActionLink("Create New Instructor", "Create", null, new { @class = "btn btn-primary" })
</div>

<!-- INSTRUCTOR LIST -->
<div class="card shadow-sm mt-4">
    <div class="card-body">

        <h4 class="mb-3">Instructor List</h4>
        <hr />

        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Last Name</th>
                    <th>First Name</th>
                    <th>Hire Date</th>
                    <th>Office</th>
                    <th>Courses</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model.Instructors)
                {
                    bool isSelected = item.ID == ViewBag.InstructorID;
                    string rowClass = isSelected ? "table-success" : "";

                    <tr class="@rowClass">
                        <td>@item.LastName</td>
                        <td>@item.FirstMidName</td>
                        <td>@item.HireDate.ToShortDateString()</td>
                        <td>@item.OfficeAssignment?.Location</td>

                        <td>
                            @if (item.Courses != null && item.Courses.Any())
                            {
                                foreach (var course in item.Courses)
                                {
                                    <span>@course.CourseID - @course.Title</span><br />
                                }
                            }
                            else
                            {
                                <span class="text-muted">No courses assigned</span>
                            }
                        </td>

                        <td class="text-end">
                            @Html.ActionLink("Select", "Index", new { id = item.ID }, new { @class = "btn btn-sm btn-secondary me-1" })
                            @Html.ActionLink("Edit", "Edit", new { id = item.ID }, new { @class = "btn btn-sm btn-primary me-1" })
                            @Html.ActionLink("Details", "Details", new { id = item.ID }, new { @class = "btn btn-sm btn-info text-white me-1" })
                            @Html.ActionLink("Delete", "Delete", new { id = item.ID }, new { @class = "btn btn-sm btn-danger" })
                        </td>
                    </tr>
                }
            </tbody>
        </table>

    </div>
</div>

<!-- COURSES FOR SELECTED INSTRUCTOR -->
@if (Model.Courses != null)
{
    <div class="card shadow-sm mt-4">
        <div class="card-body">

            <h4 class="mb-3">Courses Taught by Selected Instructor</h4>
            <hr />

            <table class="table table-striped table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th></th>
                        <th>Number</th>
                        <th>Title</th>
                        <th>Department</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model.Courses)
                    {
                        bool isSelected = item.CourseID == ViewBag.CourseID;
                        string rowClass = isSelected ? "table-success" : "";

                        <tr class="@rowClass">
                            <td>
                                @Html.ActionLink("Select", "Index", new { courseID = item.CourseID }, new { @class = "btn btn-sm btn-secondary" })
                            </td>
                            <td>@item.CourseID</td>
                            <td>@item.Title</td>
                            <td>@item.Department?.Name</td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    </div>
}

<!-- STUDENTS ENROLLED IN SELECTED COURSE -->
@if (Model.Enrollments != null)
{
    <div class="card shadow-sm mt-4 mb-4">
        <div class="card-body">

            <h4 class="mb-3">Students Enrolled in Selected Course</h4>
            <hr />

            <table class="table table-striped table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Name</th>
                        <th>Grade</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model.Enrollments)
                    {
                        <tr>
                            <td>@item.Student?.FullName</td>
                            <td>@Html.DisplayFor(m => item.Grade)</td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    </div>
}
