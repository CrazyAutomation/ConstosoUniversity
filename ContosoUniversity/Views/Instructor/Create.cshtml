@model ContosoUniversity.Models.Instructor

@{
    ViewBag.Title = "Create Instructor";
}

<h2 class="mt-3">Create Instructor</h2>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <div class="card shadow-sm mt-4">
        <div class="card-body">

            <h4 class="mb-3">Instructor Information</h4>
            <hr />

            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            <div class="mb-3">
                @Html.LabelFor(m => m.LastName, new { @class = "form-label" })
                @Html.TextBoxFor(m => m.LastName, new { @class = "form-control" })
                @Html.ValidationMessageFor(m => m.LastName, "", new { @class = "text-danger" })
            </div>

            <div class="mb-3">
                @Html.LabelFor(m => m.FirstMidName, new { @class = "form-label" })
                @Html.TextBoxFor(m => m.FirstMidName, new { @class = "form-control" })
                @Html.ValidationMessageFor(m => m.FirstMidName, "", new { @class = "text-danger" })
            </div>

            <div class="mb-3">
                @Html.LabelFor(m => m.HireDate, new { @class = "form-label" })
                @Html.TextBoxFor(m => m.HireDate, new { @class = "form-control", type = "date" })
                @Html.ValidationMessageFor(m => m.HireDate, "", new { @class = "text-danger" })
            </div>

            <div class="mb-3">
                @Html.LabelFor(m => m.OfficeAssignment.Location, "Office Location", new { @class = "form-label" })
                @Html.TextBoxFor(m => m.OfficeAssignment.Location, new { @class = "form-control" })
                @Html.ValidationMessageFor(m => m.OfficeAssignment.Location, "", new { @class = "text-danger" })
            </div>

            <h5 class="mt-4">Assigned Courses</h5>
            <hr />

            <div class="row">
                @{
                    List<ContosoUniversity.ViewModels.AssignedCourseData> courses = ViewBag.Courses;
                    foreach (var course in courses)
                    {
                        <div class="col-md-4 mb-2">
                            <div class="form-check">
                                <input type="checkbox"
                                       class="form-check-input"
                                       name="selectedCourses"
                                       value="@course.CourseID"
                                       @(course.Assigned ? "checked=\"checked\"" : "") />

                                <label class="form-check-label">
                                    @course.CourseID - @course.Title
                                </label>
                            </div>
                        </div>
                    }
                }
            </div>

            <button type="submit" class="btn btn-primary mt-3">Create</button>
            @Html.ActionLink("Back to List", "Index", null, new { @class = "btn btn-secondary mt-3 ms-2" })

        </div>
    </div>
}

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
